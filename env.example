# MongoDB Connection URI
# Replace with your actual MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/event-space
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGODB_URI=mongodb://localhost:27017/projectname

# Server Port
PORT=8000

# Local API host for physical mobile devices (optional)
# Android emulator uses 10.0.2.2 by default if unset
# iOS simulator uses localhost by default if unset
# Example: EXPO_PUBLIC_LOCAL_API_HOST=192.168.1.3
EXPO_PUBLIC_LOCAL_API_HOST=
